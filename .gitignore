```gitignore
# =========================================================
# StackPilot .gitignore
# Python + PyInstaller + TUI + future Tauri/Rust GUI
# =========================================================


# ---------------------------------------------------------
# Python cache / bytecode
# ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd


# ---------------------------------------------------------
# Python virtual environments
# ---------------------------------------------------------
venv/
.venv/
env/
.env/
ENV/


# ---------------------------------------------------------
# Python build / packaging
# ---------------------------------------------------------
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/
wheels/


# ---------------------------------------------------------
# PyInstaller
# ---------------------------------------------------------
*.spec
*.manifest
*.pyz


# ---------------------------------------------------------
# Test / coverage / lint cache
# ---------------------------------------------------------
.pytest_cache/
.pytest_tmp/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.pyre/
.ruff_cache/
.hypothesis/


# ---------------------------------------------------------
# Local generated outputs
# ---------------------------------------------------------
outputs/
reports/
logs/
*.log
*.tmp
*.bak


# ---------------------------------------------------------
# StackPilot generated files
# ---------------------------------------------------------
stackpilot-report.md
stackpilot-report.json
install-plan.md
install-plan.json
install-audit.md
install-audit.json
snapshot-plan.md
snapshot-plan.json
rollback-plan.md
rollback-plan.json
dry-run.md
dry-run.json


# ---------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------
.env
.env.*
!.env.example
*.local


# ---------------------------------------------------------
# Windows / macOS / Linux system files
# ---------------------------------------------------------
Thumbs.db
Desktop.ini
.DS_Store
.AppleDouble
.LSOverride
._*
.Trashes
.fseventsd/
.Spotlight-V100/


# ---------------------------------------------------------
# IDE / editor
# ---------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.swn
*.iml


# ---------------------------------------------------------
# PowerShell / local scripts cache
# ---------------------------------------------------------
*.ps1xml
*.pssc
*.psrc


# ---------------------------------------------------------
# Node / frontend / future Tauri GUI
# ---------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.next/
.nuxt/
.svelte-kit/
vite.config.*.timestamp-*


# ---------------------------------------------------------
# Tauri / Rust build cache
# ---------------------------------------------------------
target/
src-tauri/target/


# ---------------------------------------------------------
# Native build artifacts
# ---------------------------------------------------------
*.exe
*.dll
*.lib
*.obj
*.pdb
*.ilk
*.exp
*.so
*.dylib
*.a
*.o


# ---------------------------------------------------------
# Local AI / Codex / personal notes
# ---------------------------------------------------------
AGENTS.md
AGENTS.local.md
.codex/
.openai/
.gemini/
.grok/


# ---------------------------------------------------------
# Do not ignore important project files
# ---------------------------------------------------------
!README.md
!LICENSE
!pyproject.toml
!requirements.txt
!requirements-dev.txt
!package.json
!pnpm-lock.yaml
!Cargo.toml
!Cargo.lock
```

